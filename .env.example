SPRING_PROFILES_ACTIVE=dev

# dev usa H2 em memoria por padrao, sem DATABASE_*.
#
# Para Postgres local/Docker, use:
# SPRING_PROFILES_ACTIVE=local-postgres
# DATABASE_URL=jdbc:postgresql://localhost:5432/cardapio
# DATABASE_USERNAME=cardapio
# DATABASE_PASSWORD=cardapio

# Para Supabase usando o Session Pooler, use:
# SPRING_PROFILES_ACTIVE=supabase
# DATABASE_URL=jdbc:postgresql://aws-1-us-west-1.pooler.supabase.com:5432/postgres?sslmode=require
# DATABASE_USERNAME=postgres.hjigxbjeeecuehlbxxny
# DATABASE_PASSWORD=sua-senha-do-banco
#
# Para Supabase direct connection, use somente se sua rede tiver IPv6:
# DATABASE_URL=jdbc:postgresql://db.hjigxbjeeecuehlbxxny.supabase.co:5432/postgres?sslmode=require
# DATABASE_USERNAME=postgres

JWT_SECRET=troque-por-um-segredo-forte-com-32-caracteres-ou-mais
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000
JWT_ISSUER=cardapio-online

COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax
COOKIE_DOMAIN=

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=troque-pela-service-role-key-ou-chave-com-permissao-de-storage
SUPABASE_BUCKET=cardapio-imagens

MAX_FILE_SIZE=5MB
MAX_REQUEST_SIZE=5MB
